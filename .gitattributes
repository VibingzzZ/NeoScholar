# 所有文本文件统一用 LF 换行符
* text=auto eol=lf

# Windows 批处理文件需要 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.gz binary
*.tar binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.class binary
